server:
  port: 8080

spring:
  datasource:
    url: jdbc:h2:file:./data/studynote;DB_CLOSE_DELAY=-1;MODE=MySQL
    driver-class-name: org.h2.Driver
    username: sa
    password:
  h2:
    console:
      enabled: true
      path: /h2-console
  sql:
    init:
      mode: always
      schema-locations: classpath:schema.sql

mybatis-plus:
  configuration:
    map-underscore-to-camel-case: true
  global-config:
    db-config:
      id-type: auto

deepseek:
  api-key: ${DEEPSEEK_API_KEY:your-api-key-here}
  api-url: https://api.deepseek.com/chat/completions
